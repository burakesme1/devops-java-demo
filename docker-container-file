FROM jenkins/jenkins:lts
 
USER root
 
# Base packages + Docker install

RUN apt-get update && apt-get install -y \

    curl \

    git \

    ca-certificates \

    apt-transport-https \

    gnupg \

    lsb-release \

    docker.io \

    wget \
&& rm -rf /var/lib/apt/lists/*
 
# kubectl install

RUN curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" \
&& install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl \
&& rm kubectl
 
# Trivy install

RUN wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key \

    | gpg --dearmor \

    | tee /usr/share/keyrings/trivy.gpg > /dev/null
 
RUN echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" \
> /etc/apt/sources.list.d/trivy.list
 
RUN apt-get update && apt-get install -y trivy \
&& rm -rf /var/lib/apt/lists/*
 
# Jenkins user docker grubuna ekleniyor

RUN usermod -aG docker jenkins
 
USER jenkins
 
EXPOSE 8080

EXPOSE 50000